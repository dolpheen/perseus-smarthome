# Raspberry Pi connection used by deploy and E2E helper scripts.
# Real values belong in .env, which is gitignored.

RPI_SSH_HOST=raspberrypi.local
RPI_SSH_PORT=22
RPI_SSH_USER=pi
RPI_SSH_KEY_PATH=

# Prefer SSH keys or ssh-agent. Use a password only for local development if needed.
RPI_SSH_PASSWORD=

RPI_DISCOVERY_SUBNET=
RPI_MCP_HOST=raspberrypi.local
RPI_MCP_PORT=8000
RPI_MCP_URL=http://raspberrypi.local:8000/mcp
