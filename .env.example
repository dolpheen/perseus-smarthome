# Raspberry Pi connection used by deploy and E2E helper scripts.
# Real values belong in .env, which is gitignored.

RPI_SSH_HOST=raspberrypi.local
RPI_SSH_PORT=22
RPI_SSH_USER=pi
RPI_SSH_KEY_PATH=

# Prefer SSH keys or ssh-agent. Use a password only for local development if needed.
RPI_SSH_PASSWORD=

RPI_DISCOVERY_SUBNET=
RPI_MCP_HOST=raspberrypi.local
RPI_MCP_PORT=8000
RPI_MCP_URL=http://raspberrypi.local:8000/mcp

# LLM agent layer (Milestone 2).  Real values belong in .env (gitignored).
# For the default OpenRouter route, prefer OPENROUTER_API_KEY. OPENAI_API_KEY
# is also accepted because OpenRouter is OpenAI-compatible.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=tencent/hy3-preview:free

# Optional LangSmith tracing for LangChain / Deep Agents.
LANGSMITH_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=perseus-smarthome

# Deprecated fallback accepted for existing installs; prefer OPENROUTER_API_KEY
# or OPENAI_API_KEY in new .env files.
# LLM_API_KEY=

AGENT_CHAT_HOST=0.0.0.0
AGENT_CHAT_PORT=8765
AGENT_RPI_MCP_URL=http://127.0.0.1:8000/mcp
